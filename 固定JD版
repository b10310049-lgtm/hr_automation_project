                            time.sleep(1)
                            
                    log_status.update(label=f"🎉 執行完畢！共實質發送 {trigger_count} 封郵件。", state="complete", expanded=True)
                    time.sleep(1)
                    st.rerun()
                except Exception as e:
                    st.error(f"❌ 郵件發送引擎崩潰：{e}")
